{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}"
    },
    {
      "name": "windows-vcpkg",
      "displayName": "Windows (MSVC + vcpkg manifest)",
      "description": "Uses vcpkg manifest mode to install Boost from vcpkg.json.",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build-win",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux",
      "displayName": "Linux/WSL (system Boost)",
      "description": "Uses system packages (e.g. libboost-system-dev). Does not invoke vcpkg.",
      "inherits": "base",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux/WSL Debug (system Boost)",
      "inherits": "linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-release",
      "displayName": "Windows Release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "windows-vcpkg-debug",
      "displayName": "Windows Debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "configurePreset": "linux"
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "configurePreset": "linux-debug"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vcpkg-release",
      "displayName": "Windows Release tests",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release tests",
      "configurePreset": "linux"
    }
  ]
}
